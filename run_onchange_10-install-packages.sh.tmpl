#!/usr/bin/env bash
set -euo pipefail

log() {
  printf "==> %s\n" "$*"
}

has() {
  command -v "$1" >/dev/null 2>&1
}

# =========================================
# CHEZMOI SAFE DEFAULTS (ВАЖНО)
# =========================================

{{- $base := default "lite" .base }}
{{- $packages := default (dict) .packages }}

{{- $apt := default (dict) $packages.apt }}
{{- $brew := default (dict) $packages.brew }}
{{- $cargo := default (dict) $packages.cargo }}

# =========================================
# APT (Linux system packages)
# =========================================

log "APT phase"

if has apt; then
  if [ "$(id -u)" -eq 0 ]; then
    APT_CMD="apt"
  elif has sudo; then
    APT_CMD="sudo apt"
  else
    log "apt found but no sudo/root → skipping"
    APT_CMD=""
  fi

  if [ -n "$APT_CMD" ]; then
    $APT_CMD update -y

    {{- if eq .chezmoi.os "linux" }}
    {{- $aptLinux := default (list) (get $apt "linux") }}

    {{- if gt (len $aptLinux) 0 }}
    APT_PACKAGES=(
      {{- range $aptLinux }}
      "{{ . }}"
      {{- end }}
    )

    log "Installing apt packages"
    $APT_CMD install -y "${APT_PACKAGES[@]}"
    {{- else }}
    log "No apt packages defined"
    {{- end }}
    {{- else }}
    log "Not linux → skipping apt"
    {{- end }}
  fi
else
  log "apt not available"
fi

# =========================================
# HOMEBREW
# =========================================

install_brew() {
  if has brew; then
    return
  fi

  if ! has curl; then
    log "curl missing → cannot install brew"
    return
  fi

  log "Installing Homebrew"

  NONINTERACTIVE=1 \
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  elif [[ -d "/opt/homebrew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -d "/usr/local/Homebrew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

install_brew

log "Brew phase"

if has brew; then
  brew update

  {{- $brewLite := default (list) (get $brew "lite") }}
  {{- $brewFull := default (list) (get $brew "full") }}
  {{- $brewLinux := default (list) (get $brew "linux") }}
  {{- $brewMac := default (list) (get $brew "macos") }}

  # проверка: есть ли вообще пакеты
  BREW_HAS=0
  {{- if and (eq $base "lite") (gt (len $brewLite) 0) }}BREW_HAS=1{{ end }}
  {{- if and (eq $base "full") (gt (len $brewFull) 0) }}BREW_HAS=1{{ end }}
  {{- if and (eq .chezmoi.os "linux") (gt (len $brewLinux) 0) }}BREW_HAS=1{{ end }}
  {{- if and (eq .chezmoi.os "darwin") (gt (len $brewMac) 0) }}BREW_HAS=1{{ end }}

  if [ "$BREW_HAS" -eq 0 ]; then
    log "No brew packages"
  else
    log "Running brew bundle"

    brew bundle --no-lock --file=/dev/stdin <<EOF
# --- base ---
{{- if eq $base "lite" }}
  {{- range $brewLite }}
brew "{{ . }}"
  {{- end }}
{{- end }}

{{- if eq $base "full" }}
  {{- range $brewFull }}
brew "{{ . }}"
  {{- end }}
{{- end }}

# --- platform ---
{{- if eq .chezmoi.os "linux" }}
  {{- range $brewLinux }}
brew "{{ . }}"
  {{- end }}
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
  {{- range $brewMac }}
brew "{{ . }}"
  {{- end }}
{{- end }}
EOF

  fi
else
  log "brew not available"
fi

# =========================================
# CARGO
# =========================================

install_rust() {
  if has cargo; then
    return
  fi

  if ! has curl; then
    log "curl missing → cannot install rust"
    return
  fi

  log "Installing Rust"

  curl https://sh.rustup.rs -sSf | sh -s -- -y
  # shellcheck disable=SC1091
  source "$HOME/.cargo/env"
}

install_rust

log "Cargo phase"

if has cargo; then
  {{- $cargoLite := default (list) (get $cargo "lite") }}
  {{- $cargoFull := default (list) (get $cargo "full") }}

  CARGO_PACKAGES=()

  {{- if eq $base "lite" }}
    {{- range $cargoLite }}
  CARGO_PACKAGES+=("{{ . }}")
    {{- end }}
  {{- end }}

  {{- if eq $base "full" }}
    {{- range $cargoFull }}
  CARGO_PACKAGES+=("{{ . }}")
    {{- end }}
  {{- end }}

  if [ "${#CARGO_PACKAGES[@]}" -eq 0 ]; then
    log "No cargo packages"
  else
    for pkg in "${CARGO_PACKAGES[@]}"; do
      if ! cargo install --list | grep -q "^$pkg "; then
        log "cargo install $pkg"
        cargo install "$pkg"
      else
        log "cargo skip $pkg"
      fi
    done
  fi
else
  log "cargo not available"
fi

log "Done"
