#!/bin/bash

# .chezmoidata/packages.yaml hash:

CMD=$( [ "$(id -u)" -eq 0 ] && echo "" || echo "sudo " )

{{- $os := .chezmoi.os -}}
{{- $profiles := index . "profiles" | default (list "full") -}}
{{- $pkgs_data := index . "packages" | default (dict) -}}

{{- if and (eq $os "linux") (index $pkgs_data "apt") }}
echo "Installing APT packages..."
${CMD}apt-get update
{{- range $type, $pkgs := index $pkgs_data "apt" }}
  {{- if or (eq $type "all") (eq $type "common") (eq $type $os) (has $type $profiles) }}
    {{- range $pkgs }}
${CMD}apt-get install -y {{ . | quote }}
    {{- end }}
  {{- end }}
{{- end }}
{{- end }}

if ! command -v brew &> /dev/null; then
    echo "Installing Homebrew..."

    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    {{ if eq $os "linux" -}}
    test -d ~/.linuxbrew && eval "$(~/.linuxbrew/bin/brew shellenv)"
    test -d /home/linuxbrew/.linuxbrew && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    {{ else -}}
    test -d /usr/local/bin/brew && eval "$(/usr/local/bin/brew shellenv)"
    test -d /opt/homebrew/bin/brew && eval "$(/opt/homebrew/bin/brew shellenv)"
    {{- end }}
fi

{{- if (index $pkgs_data "brew") }}
echo "Installing Brew packages..."
{{- range $type, $pkgs := index $pkgs_data "brew" }}
  {{- if or (eq $type "all") (eq $type "common") (eq $type $os) (has $type $profiles) }}
    {{- range $pkgs }}
brew {{ . | quote }}
    {{- end }}
  {{- end }}
{{- end }}
EOF
{{- end }}

{{- if not (has "lite" $profiles) }}
if ! command -v cargo &> /dev/null; then
    echo "Installing Rust/Cargo..."
    curl https://sh.rustup.rs -sSf | sh
    source "$HOME/.cargo/env"
fi

{{- if (index $pkgs_data "cargo") }}
echo "Installing Cargo packages..."
{{- range $type, $pkgs := index $pkgs_data "cargo" }}
  {{- if or (eq $type "all") (eq $type "common") (eq $type $os) (has $type $profiles) }}
    {{- range $pkgs }}
cargo install {{ . | quote }}
    {{- end }}
  {{- end }}
{{- end }}
{{- end }}
{{- end }}

echo "Installation process finished."

