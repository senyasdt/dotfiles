#!/usr/bin/env bash
set -euo pipefail

log() {
  printf "==> %s\n" "$*"
}

has() {
  command -v "$1" >/dev/null 2>&1
}

# =========================================
# SAFE CONTEXT LAYER (CRASH-PROOF)
# =========================================

{{- $root := . | default (dict) }}
{{- $base := index $root "base" | default "lite" }}

{{- $packages := index $root "packages" | default (dict) }}

{{- $apt := index $packages "apt" | default (dict) }}
{{- $brew := index $packages "brew" | default (dict) }}
{{- $cargo := index $packages "cargo" | default (dict) }}

# normalize lists (NEVER FAIL)
{{- $aptLinux := index $apt "linux" | default (list) }}

{{- $brewLite := index $brew "lite" | default (list) }}
{{- $brewFull := index $brew "full" | default (list) }}
{{- $brewLinux := index $brew "linux" | default (list) }}
{{- $brewMac := index $brew "macos" | default (list) }}

{{- $cargoLite := index $cargo "lite" | default (list) }}
{{- $cargoFull := index $cargo "full" | default (list) }}

# =========================================
# APT (safe, Linux only)
# =========================================

log "APT phase"

if has apt; then
  if [ "$(id -u)" -eq 0 ]; then
    APT_CMD="apt"
  elif has sudo; then
    APT_CMD="sudo apt"
  else
    log "no sudo/root → skip apt"
    APT_CMD=""
  fi

  if [ -n "${APT_CMD:-}" ]; then
    $APT_CMD update -y

    if [ "{{ .chezmoi.os }}" = "linux" ]; then
      if [ "${#aptLinux[@]}" -gt 0 ]; then
        log "installing apt packages"
        $APT_CMD install -y "${aptLinux[@]}"
      else
        log "no apt linux packages"
      fi
    else
      log "not linux → skip apt"
    fi
  fi
else
  log "apt not available"
fi

# =========================================
# HOMEBREW (bulletproof bootstrap)
# =========================================

install_brew() {
  if has brew; then
    return
  fi

  if ! has curl; then
    log "curl missing → skip brew"
    return
  fi

  log "installing Homebrew"

  NONINTERACTIVE=1 \
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  elif [[ -d "/opt/homebrew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -d "/usr/local/Homebrew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

install_brew

log "brew phase"

if has brew; then
  brew update

  BREW_PACKAGES=()

  # base selection
  if [ "$base" = "lite" ]; then
    BREW_PACKAGES+=("${brewLite[@]}")
  elif [ "$base" = "full" ]; then
    BREW_PACKAGES+=("${brewFull[@]}")
  fi

  # platform
  if [ "{{ .chezmoi.os }}" = "linux" ]; then
    BREW_PACKAGES+=("${brewLinux[@]}")
  fi

  if [ "{{ .chezmoi.os }}" = "darwin" ]; then
    BREW_PACKAGES+=("${brewMac[@]}")
  fi

  # deduplicate safely
  mapfile -t BREW_PACKAGES < <(printf "%s\n" "${BREW_PACKAGES[@]}" | awk '!seen[$0]++')

  if [ "${#BREW_PACKAGES[@]}" -gt 0 ]; then
    log "installing brew packages"

    brew bundle --file=/dev/stdin <<EOF
$(for p in "${BREW_PACKAGES[@]}"; do echo "brew \"$p\""; done)
EOF

  else
    log "no brew packages"
  fi
else
  log "brew not available"
fi

# =========================================
# CARGO (safe rust tools)
# =========================================

install_rust() {
  if has cargo; then
    return
  fi

  if ! has curl; then
    log "curl missing → skip rust"
    return
  fi

  log "installing rust"

  curl https://sh.rustup.rs -sSf | sh -s -- -y
  # shellcheck disable=SC1091
  source "$HOME/.cargo/env"
}

install_rust

log "cargo phase"

if has cargo; then
  CARGO_PACKAGES=()

  if [ "$base" = "lite" ]; then
    CARGO_PACKAGES+=("${cargoLite[@]}")
  elif [ "$base" = "full" ]; then
    CARGO_PACKAGES+=("${cargoFull[@]}")
  fi

  if [ "${#CARGO_PACKAGES[@]}" -gt 0 ]; then
    for pkg in "${CARGO_PACKAGES[@]}"; do
      if ! cargo install --list | grep -q "^$pkg "; then
        log "cargo install $pkg"
        cargo install "$pkg"
      else
        log "skip $pkg"
      fi
    done
  else
    log "no cargo packages"
  fi
else
  log "cargo not available"
fi

log "done"
