#!/usr/bin/env bash

# Force bash
[ -z "${BASH_VERSION:-}" ] && exec bash "$0" "$@"

set -euo pipefail

OS="{{ .chezmoi.os }}"

# --- PROFILES FROM CHEZMOI_DATA ---
{{- $profiles := (index .chezmoi.args "profiles") | default "full" -}}
{{- $profiles := (kindIs "slice" $profiles) | ternary $profiles (splitList "," $profiles) -}}
PROFILES=({{- range $profiles }}{{ . | quote }} {{ end }})

log() { printf "==> %s\n" "$*"; }
has() { command -v "$1" >/dev/null 2>&1; }

# =========================================
# APT
# =========================================
if [ "$OS" = "linux" ] && has apt; then
  log "APT phase"

  APT_PKGS=(
    {{- range (index .packages.apt "linux" | default list) }}
    "{{ . }}"
    {{- end }}
  )

  if [ "${#APT_PKGS[@]}" -gt 0 ]; then
    CMD=$( [ "$(id -u)" -eq 0 ] && echo "apt" || echo "sudo apt" )
    $CMD update -y
    $CMD install -y "${APT_PKGS[@]}"
  fi
fi

# =========================================
# BREW
# =========================================
install_brew() {
  if has brew; then return; fi

  if [ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    return
  fi

  if [ -f "/opt/homebrew/bin/brew" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    return
  fi

  if has curl; then
    log "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null || true)"
    eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || true)"
  fi
}

install_brew

if has brew; then
  log "Brew phase"

  BREW_PKGS=()

  # profiles
  {{- range $profile := $profiles }}
  {{- range (index $.packages.brew $profile | default list) }}
  BREW_PKGS+=("{{ . }}")
  {{- end }}
  {{- end }}

  # OS-specific
  {{- if eq .chezmoi.os "linux" }}
  {{- range (index .packages.brew "linux" | default list) }}
  BREW_PKGS+=("{{ . }}")
  {{- end }}
  {{- end }}

  {{- if eq .chezmoi.os "darwin" }}
  {{- range (index .packages.brew "macos" | default list) }}
  BREW_PKGS+=("{{ . }}")
  {{- end }}
  {{- end }}

  if [ "${#BREW_PKGS[@]}" -gt 0 ]; then
    mapfile -t BREW_PKGS < <(printf "%s\n" "${BREW_PKGS[@]}" | sort -u)
    brew install "${BREW_PKGS[@]}"
  fi
fi

# =========================================
# CARGO
# =========================================
install_rust() {
  if has cargo; then return; fi

  if has curl; then
    log "Installing Rust..."
    curl https://sh.rustup.rs -sSf | sh -s -- -y
    [ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
  fi
}

install_rust

if has cargo; then
  log "Cargo phase"

  CARGO_PKGS=()

  {{- range $profile := $profiles }}
  {{- range (index $.packages.cargo $profile | default list) }}
  CARGO_PKGS+=("{{ . }}")
  {{- end }}
  {{- end }}

  if [ "${#CARGO_PKGS[@]}" -gt 0 ]; then
    mapfile -t CARGO_PKGS < <(printf "%s\n" "${CARGO_PKGS[@]}" | sort -u)

    for pkg in "${CARGO_PKGS[@]}"; do
      if ! cargo install --list | grep -q "^$pkg "; then
        log "Installing $pkg"
        cargo install "$pkg"
      fi
    done
  fi
fi

log "Done"
