#!/usr/bin/env bash
set -e

. /etc/profile.d/nix.sh || true

echo "==> Installing packages via apt (if available)"

if command -v apt >/dev/null 2>&1; then
  if [ "$(id -u)" -eq 0 ]; then
    APT_CMD="apt"
  elif command -v sudo >/dev/null 2>&1; then
    APT_CMD="sudo apt"
  else
    echo "apt found but no sudo and not root, skipping apt packages"
    APT_CMD=""
  fi

  if [ -n "$APT_CMD" ]; then
    $APT_CMD update

    {{- if eq .chezmoi.os "linux" }}
    {{- $aptLinux := default (list) .apt.packages.linux }}
    {{- if gt (len $aptLinux) 0 }}
    $APT_CMD install -y \
    {{- range $aptLinux }}
      {{ . }} \
    {{- end }}
    {{- end }}
    {{- end }}
  fi
else
  echo "apt not found, skipping apt packages"
fi

echo "==> Installing packages via Nix"

{{- $nixCommon := default (list) .nix.packages.common }}
{{- $nixLinux := default (list) .nix.packages.linux }}
{{- $nixDarwin := default (list) .nix.packages.darwin }}

{{- if or
      (gt (len $nixCommon) 0)
      (and (eq .chezmoi.os "linux") (gt (len $nixLinux) 0))
      (and (eq .chezmoi.os "darwin") (gt (len $nixDarwin) 0))
}}
nix profile add \
{{- range $nixCommon }}
  nixpkgs#{{ . }} \
{{- end }}
{{- if eq .chezmoi.os "linux" }}
  {{- range $nixLinux }}
  nixpkgs#{{ . }} \
  {{- end }}
{{- else if eq .chezmoi.os "darwin" }}
  {{- range $nixDarwin }}
  nixpkgs#{{ . }} \
  {{- end }}
{{- end }}
{{- else }}
echo "No Nix packages to install"
{{- end }}
